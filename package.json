{
  "name": "democratic-chess",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "workspaces": ["client", "server", "packages/*"],
  "scripts": {
    "dev:client": "npm --workspace client run dev",
    "dev:server": "npm --workspace @democratic-chess/types run build && npm --workspace server run dev",
    "dev": "concurrently -n client,server -c blue,green \"npm:dev:client\" \"npm:dev:server\"",
    "build": "npm --workspace @democratic-chess/types run build && npm --workspace server run build && npm --workspace client run build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "concurrently": "^9.0.0",
    "eslint": "^9.9.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.4",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}

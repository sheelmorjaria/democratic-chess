# HTTP / realtime server (uWS owns this port; plain HTTP is forwarded to Express
# on INTERNAL_PORT).
PORT=3001
INTERNAL_PORT=3002
CLIENT_ORIGIN="http://localhost:3000"

# PostgreSQL (matches docker-compose.yml)
DATABASE_URL="postgresql://chess:chess@localhost:5432/democratic_chess?schema=public"

# Redis (matches docker-compose.yml)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-in-production"

# WebRTC team voice (P2P mesh). STUN is always on; TURN is included only when
# all three are set. Start coturn: `docker compose --profile turn up coturn`.
# TURN_URL must be reachable from the browser (localhost:3478 for local dev).
TURN_URL="turn:localhost:3478"
TURN_USER="dc"
TURN_PASS="dcturn"

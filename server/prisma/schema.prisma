// DemocraticChess — durable schema (PostgreSQL via Prisma).
// See specs/001-democratic-chess/data-model.md for the entity design.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TeamColor {
  WHITE
  BLACK
}

enum MatchMode {
  TEAM_VS_TEAM
  SOLO_VS_TEAM
}

enum MatchStatus {
  WAITING
  ACTIVE
  COMPLETED
  ABORTED
}

enum MatchWinner {
  WHITE
  BLACK
  DRAW
}

enum TeamRole {
  CAPTAIN
  MEMBER
}

enum RatingSubjectType {
  TEAM
  SOLO
}

model User {
  id           String              @id @default(uuid())
  username     String              @unique
  email        String              @unique
  passwordHash String
  createdAt    DateTime            @default(now())

  captainedTeams Team[]            @relation("TeamCaptain")
  memberships  TeamMembership[]
  participations MatchParticipant[]
  soloRating   Rating?             @relation("SoloRating")

  @@index([email])
  @@index([username])
}

model Team {
  id        String   @id @default(uuid())
  name      String   @unique
  captain   User     @relation("TeamCaptain", fields: [captainId], references: [id])
  captainId String
  createdAt DateTime @default(now())

  members      TeamMembership[]
  rating       Rating?         @relation("TeamRating")
  whiteMatches Match[]         @relation("WhiteTeam")
  blackMatches Match[]         @relation("BlackTeam")

  @@index([captainId])
}

model TeamMembership {
  id       String   @id @default(uuid())
  team     Team     @relation(fields: [teamId], references: [id])
  teamId   String
  user     User     @relation(fields: [userId], references: [id])
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  @@unique([teamId, userId])
  @@index([userId])
}

model Match {
  id                   String       @id @default(uuid())
  mode                 MatchMode    @default(TEAM_VS_TEAM)
  status               MatchStatus  @default(WAITING)
  winner               MatchWinner?
  fen                  String       @default("rnbqkbnr/pppppppp/8/8/8/8/PPPPPPPP/RNBQKBNR w KQkq - 0 1")
  turn                 TeamColor    @default(WHITE)
  turnNumber           Int          @default(1)
  moveWindowSec        Int          @default(60)
  whiteTimeRemainingMs Int          @default(600000)
  blackTimeRemainingMs Int          @default(600000)
  startedAt            DateTime?
  endedAt              DateTime?

  whiteTeam   Team?  @relation("WhiteTeam", fields: [whiteTeamId], references: [id])
  whiteTeamId String?
  blackTeam   Team?  @relation("BlackTeam", fields: [blackTeamId], references: [id])
  blackTeamId String?

  participants MatchParticipant[]

  @@index([status])
}

model MatchParticipant {
  id        String    @id @default(uuid())
  match     Match     @relation(fields: [matchId], references: [id])
  matchId   String
  user      User      @relation(fields: [userId], references: [id])
  userId    String
  teamColor TeamColor
  isCaptain Boolean   @default(false)

  @@unique([matchId, userId])
  @@index([matchId])
}

// Polymorphic-by-convention rating: exactly one of (teamId, userId) is set,
// disambiguated by subjectType. Enforced in the service layer.
model Rating {
  id               String            @id @default(uuid())
  subjectType      RatingSubjectType
  rating           Int               @default(1200)
  wins             Int               @default(0)
  losses           Int               @default(0)
  draws            Int               @default(0)
  provisionalGames Int               @default(0)
  updatedAt        DateTime          @updatedAt

  team   Team?   @relation("TeamRating", fields: [teamId], references: [id])
  teamId String? @unique
  user   User?   @relation("SoloRating", fields: [userId], references: [id])
  userId String? @unique

  @@index([subjectType, rating])
}
